# Layer 5 environment variables template
# COPY this to .env and fill in real values. NEVER commit .env to git!

# Database
DB_USER=bookshelf_user
DB_PASS=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=mybookshelf

# Application
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING
ENVIRONMENT=production

# Domain (for TLS certificates)
DOMAIN=mybookshelf.example.com

# Hetzner Cloud (for deploy.py)
HETZNER_API_TOKEN=your-api-token-here
